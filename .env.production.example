# ============================================================
#  Numi Platform — Production Environment Configurations
# ============================================================

PLATFORM_MODE=production
PORT=8080

# API Configuration
API_BASE_URL=https://api.numi.education/v1

# Security & Auth
JWT_SECRET=your_super_secret_jwt_key_here
SESSION_EXPIRY=86400

# Database
DB_CONNECTION_STRING=mongodb+srv://admin:pass@cluster.mongodb.net/numi_prod
DB_POOL_SIZE=100

# External AI Provider (Google Gemini / OpenAI / Anthropic)
AI_PROVIDER_KEY=your_ai_api_key_here
AI_MODEL_PRIMARY=gemini-1.5-flash
AI_MODEL_FALLBACK=gemini-1.5-pro

# File Storage (AWS S3 or Cloudflare R2 for RAG documents)
STORAGE_BUCKET=numi-prod-documents
STORAGE_REGION=me-south-1

# Billing & Stripe (Optional)
STRIPE_SECRET_KEY=sk_live_...
