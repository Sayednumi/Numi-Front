# Numi SaaS - Production Environment Configuration
# DO NOT COMMIT THIS FILE WITH REAL SECRETS

# Core Environment
NODE_ENV=production
PORT=3000
API_BASE_URL=https://api.numi.education/v1

# Security & Authentication
JWT_SECRET=super_secret_production_key_numi_2026
SESSION_SECRET=super_secret_session_key_numi

# Tenant & Organization
TENANT_ENFORCEMENT_MODE=true

# AI & Gamification
AI_API_KEY=sk-prod-your-openai-or-anthropic-key
AI_USAGE_TRACKING=true
ENABLE_DEBUG=false

# Database / Cache
DATABASE_URL=postgres://numi_user:prod_password@db.numi.education:5432/numi_prod
REDIS_URL=redis://redis:6379

# Storage
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
AWS_S3_BUCKET_NAME=numi-production-assets

# Logging
LOG_LEVEL=production
